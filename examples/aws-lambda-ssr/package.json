{
  "name": "aws-lambda-ssr",
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "zudoku dev",
    "build": "zudoku build --experimental-ssr --adapter lambda",
    "zip": "rm -f function.zip && cd dist && zip -rqX ../function.zip . -x '*.DS_Store' '__MACOSX/*' '*.map'",
    "predeploy": "pnpm build && pnpm zip",
    "deploy": "aws lambda update-function-code --function-name ${LAMBDA_FUNCTION_NAME:-zudoku} --zip-file fileb://function.zip"
  },
  "nx": {
    "tags": [
      "example"
    ],
    "targets": {
      "build": {
        "dependsOn": [
          "zudoku:build"
        ]
      }
    }
  },
  "devDependencies": {
    "react": "catalog:",
    "react-dom": "catalog:",
    "zudoku": "workspace:*"
  }
}
