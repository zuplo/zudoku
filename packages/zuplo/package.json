{
  "name": "@zudoku/zuplo",
  "version": "0.0.1",
  "description": "Zuplo integration for Zudoku. Inspects a Zuplo project and builds the dev portal configuration for it.",
  "repository": {
    "type": "git",
    "url": "https://github.com/zuplo/zudoku",
    "directory": "packages/zuplo"
  },
  "type": "module",
  "main": "./src/node/index.ts",
  "types": "./src/node/index.ts",
  "exports": {
    ".": "./src/node/index.ts",
    "./node": "./src/node/index.ts"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "prepublishOnly": "pnpm typecheck && pnpm build",
    "typecheck": "tsc --project tsconfig.json"
  },
  "publishConfig": {
    "main": "./dist/node/index.mjs",
    "types": "./dist/node/index.d.mts",
    "exports": {
      ".": {
        "types": "./dist/node/index.d.mts",
        "import": "./dist/node/index.mjs"
      },
      "./node": {
        "types": "./dist/node/index.d.mts",
        "import": "./dist/node/index.mjs"
      }
    }
  },
  "dependencies": {
    "@zudoku/plugin-graphql": "workspace:*",
    "@zuplo/mcp": "0.0.32",
    "openapi-types": "12.1.3"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "zudoku": "workspace:*"
  },
  "peerDependencies": {
    "zudoku": ">=0.80.1"
  }
}
