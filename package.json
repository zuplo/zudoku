{
  "name": "root",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "build": "pnpm -r --filter \"./packages/*\" build",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "fix": "biome lint --write && pnpm run fmt",
    "check": "biome lint && pnpm run fmt:check && pnpm check:other",
    "check:other": "node ./scripts/check-admonitions.mjs",
    "prepare": "lefthook install",
    "changeset": "changeset",
    "version-packages": "changeset version && rm -f packages/create-zudoku/CHANGELOG.md",
    "local": "cp .env.example .env",
    "build:clean": "tsc --build --clean",
    "reset": "pnpm run build:clean",
    "clean": "git clean -Xfde !.env",
    "test": "vitest run --typecheck",
    "test:coverage": "vitest run --typecheck --coverage",
    "size": "size-limit",
    "test:e2e": "playwright test"
  },
  "engines": {
    "node": ">=22.19",
    "pnpm": ">=11"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "@changesets/cli": "2.31.0",
    "changesets-changelog-clean": "1.4.0",
    "@playwright/test": "^1.60.0",
    "@size-limit/file": "^12.1.0",
    "@vitest/coverage-v8": "4.1.8",
    "lefthook": "2.1.9",
    "oxfmt": "0.36.0",
    "publint": "^0.3.21",
    "size-limit": "^12.1.0",
    "typescript": "catalog:",
    "vitest": "4.1.0"
  },
  "size-limit": [
    {
      "path": "examples/cosmo-cargo/dist/assets/entry.client-*.js",
      "limit": "215 KB"
    }
  ],
  "packageManager": "pnpm@11.6.0"
}
