{
  "name": "root",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "build": "nx run-many -t=build",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "fix": "biome lint --write && pnpm run fmt",
    "check": "biome lint && pnpm run fmt:check && pnpm check:other",
    "check:other": "node ./scripts/check-admonitions.mjs",
    "prepare": "lefthook install",
    "release:pre": "gh workflow run release.yaml -f releaseType=prerelease",
    "release:minor": "gh workflow run release.yaml -f releaseType=minor",
    "local": "cp .env.example .env",
    "build:clean": "tsc --build --clean",
    "reset": "nx reset && npm run build:clean",
    "clean": "git clean -Xfde !.env",
    "test": "vitest run --typecheck",
    "test:coverage": "vitest run --typecheck --coverage",
    "size": "size-limit",
    "test:e2e": "playwright test"
  },
  "engines": {
    "node": ">=20.19.0 <21.0.0 || >=22.12.0",
    "pnpm": ">=10"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.6",
    "@nx/vite": "22.6.4",
    "@nx/web": "22.6.4",
    "@playwright/test": "^1.58.2",
    "@size-limit/file": "^12.0.1",
    "@vitest/coverage-v8": "4.0.18",
    "lefthook": "2.1.2",
    "nx": "22.6.4",
    "oxfmt": "0.36.0",
    "publint": "^0.3.18",
    "size-limit": "^12.0.1",
    "typescript": "catalog:",
    "vitest": "4.0.18"
  },
  "size-limit": [
    {
      "path": "examples/cosmo-cargo/dist/assets/entry.client-*.js",
      "limit": "210 KB"
    }
  ],
  "nx": {
    "includedScripts": [
      "fix",
      "check",
      "check:other"
    ]
  },
  "packageManager": "pnpm@10.32.1"
}
